{
  "version": 2,
  "builds": [
    {
      "src": "api/**/*.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    { "src": "/api/app", "dest": "api/app.js" },
    { "src": "/api/price-monitor", "dest": "api/price-monitor.js" }
  ],
  "crons": [
    {
      "path": "/api/price-monitor",
      "schedule": "0 */6 * * *", 
      "method": "POST"
    }
  ]
}
